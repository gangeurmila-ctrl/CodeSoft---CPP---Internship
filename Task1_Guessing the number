#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    char playAgain;

    do {
        int randomNumber, guess;


        // Seed random number generator
        srand(time(0));

        // Generate random number between 1 to 100
        randomNumber = rand() % 100 + 1;

        cout<<"\n======================================"<<endl;
        cout<<"     Guess the number game !"<<endl;
        cout<<"======================================"<<endl;
        cout<<" \n Welcome to Guessing number Game!!"<<endl;
        cout << "I have chosen the number between (1 to 100)." << endl;

        

        while (true) {
            cout <<" Enter your guess: ";
            cin >> guess;

            if (guess > randomNumber) {
                cout << ">>Too high! Try Smaller Number!!" << endl;
            } 
            else if (guess < randomNumber) {
                cout << ">>Too low! Try Largest Number!!" << endl;
            } 
            else {
                cout << " \n Congratulations! You guessed the correct number." << endl;
                
                break;
            }
        }


        cout << "\n Do you want to play again? (y/n): ";
        cin >> playAgain;

    } while (playAgain == 'y' || playAgain == 'Y');

    cout << "\nThanks for playing! " << endl;

    return 0;
}
